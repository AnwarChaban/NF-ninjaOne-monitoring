{
  "manifest_version": 3,
  "name": "Ninja Dashboard Widget Injector (Local)",
  "version": "0.1.0",
  "description": "Injiziert ein lokales Status-Widget als IFrame in das NinjaOne-Dashboard.",
  "content_scripts": [
    {
      "matches": [
        "https://*.rmmservice.eu/*",
        "https://app.rmmservice.eu/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://127.0.0.1:3001/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["widget.html", "widget.js", "widget.css"],
      "matches": [
        "https://*.rmmservice.eu/*",
        "https://app.rmmservice.eu/*"
      ]
    }
  ]
}